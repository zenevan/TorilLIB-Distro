## 3. Minimal Alias Template

Use this as a skeleton when building a brand-new alias from scratch.

```lua
-- ─────────────────────────────────────────────────────────────────────────
-- ALIAS: #myalias
-- REGEX: ^#myalias\s*(\S*)\s*(\S*)\s*(\S*)$
-- ARGS:  action  arg1  arg2
-- ─────────────────────────────────────────────────────────────────────────

-- ── ARG BLOCK ─────────────────────────────────────────────────────────────
local action = string.trim(matches[2] or "")
local arg1   = string.trim(matches[3] or "")
local arg2   = string.trim(matches[4] or "")

-- ── STATE BLOCK ───────────────────────────────────────────────────────────
local store = charData:get("myalias", true)

-- ── HELP ──────────────────────────────────────────────────────────────────
if action == "help" or action == "" then
  cecho("<red>Usage:\n")
  cecho("<red>  #myalias help         - this message\n")
  cecho("<red>  #myalias add  a b     - example add\n")
  cecho("<red>  #myalias del  a       - example delete\n")
  cecho("<red>  #myalias list         - show all entries\n")
  return
end

-- ── ADD ───────────────────────────────────────────────────────────────────
if action == "add" and arg1 ~= "" then
  store[arg1] = arg2
  charData:set("myalias", store, true)
  cecho("<green>[Added " .. arg1 .. " = " .. arg2 .. "]\n")
  return
end

-- ── DEL ───────────────────────────────────────────────────────────────────
if action == "del" and arg1 ~= "" then
  if store[arg1] then
    store[arg1] = nil
    charData:set("myalias", store, true)
    cecho("<green>[Deleted " .. arg1 .. "]\n")
  else
    cecho("<red>[No entry named '" .. arg1 .. "']\n")
  end
  return
end

-- ── LIST ──────────────────────────────────────────────────────────────────
if action == "list" then
  local count = 0
  for k, v in pairs(store) do
    cecho("<white>  " .. k .. " = " .. tostring(v) .. "\n")
    count = count + 1
  end
  if count == 0 then
    cecho("<yellow>[No entries stored]\n")
  end
  return
end

-- ── FALLTHROUGH ───────────────────────────────────────────────────────────
cecho("<red>[Unknown command '" .. action .. "'. Type #myalias help]\n")
```

