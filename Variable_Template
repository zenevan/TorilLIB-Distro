## 4. The #cvar Alias — Full Example

`#cvar` stores named custom variables per character, each with up to 4 value
slots. Slots auto-index as `1`, `2`, `3`, `4`. You can store fewer — empty
slots are simply not saved.

### Commands

```
#cvar help
#cvar add  name val1 [val2] [val3] [val4]
#cvar del  name
#cvar get  name
#cvar list
```

### Examples

```
#cvar add  resistfire 80
#cvar add  portal haven 3001 mage
#cvar add  buff haste stoneskin freeaction bless
#cvar get  portal
#cvar del  portal
#cvar list
```

### Storage Format

Each entry is stored under its name as a table:

```lua
store["portal"] = {
  [1] = "haven",
  [2] = "3001",
  [3] = "mage",
  [4] = ""         -- empty slots not saved, shown as blank on get
}
```

### Alias Code

**Regex:**
```
^#cvar\s*(\S*)\s*(\S*)\s*(\S*)\s*(\S*)\s*(\S*)\s*(\S*)$
```

**Lua:**
```lua
-- ─────────────────────────────────────────────────────────────────────────
-- ALIAS: #cvar
-- REGEX: ^#cvar\s*(\S*)\s*(\S*)\s*(\S*)\s*(\S*)\s*(\S*)\s*(\S*)$
-- ARGS:  action  name  val1  val2  val3  val4
-- ─────────────────────────────────────────────────────────────────────────

-- ── ARG BLOCK ─────────────────────────────────────────────────────────────
local action = string.trim(matches[2] or "")   -- add / del / get / list
local name   = string.trim(matches[3] or "")   -- variable name (key)
local val1   = string.trim(matches[4] or "")   -- value slot 1
local val2   = string.trim(matches[5] or "")   -- value slot 2
local val3   = string.trim(matches[6] or "")   -- value slot 3
local val4   = string.trim(matches[7] or "")   -- value slot 4

-- ── STATE BLOCK ───────────────────────────────────────────────────────────
local store = charData:get("cvar", true)       -- {} if not yet saved

-- ── HELP ──────────────────────────────────────────────────────────────────
if action == "help" or action == "" then
  cecho("<red>Usage:\n")
  cecho("<red>  #cvar help                          - this message\n")
  cecho("<red>  #cvar add  name val1 [v2] [v3] [v4] - store up to 4 values\n")
  cecho("<red>  #cvar del  name                     - delete a variable\n")
  cecho("<red>  #cvar get  name                     - show one variable\n")
  cecho("<red>  #cvar list                          - show all variables\n")
  return
end

-- ── ADD ───────────────────────────────────────────────────────────────────
if action == "add" then
  if name == "" then
    cecho("<red>[#cvar add requires a name]\n")
    return
  end

  -- Build value table; only store slots that have content
  local entry = {}
  local slots = { val1, val2, val3, val4 }
  local count = 0

  for i, v in ipairs(slots) do
    if v ~= "" then
      entry[i] = v
      count    = i        -- track highest filled slot
    end
  end

  if count == 0 then
    cecho("<red>[#cvar add requires at least one value]\n")
    return
  end

  store[name] = entry
  charData:set("cvar", store, true)

  -- Echo back what was saved
  local parts = {}
  for i = 1, count do
    parts[#parts+1] = "[" .. i .. "] " .. (entry[i] or "")
  end
  cecho("<green>[cvar '" .. name .. "' saved: " .. table.concat(parts, "  ") .. "]\n")
  return
end

-- ── DEL ───────────────────────────────────────────────────────────────────
if action == "del" then
  if name == "" then
    cecho("<red>[#cvar del requires a name]\n")
    return
  end

  if store[name] then
    store[name] = nil
    charData:set("cvar", store, true)
    cecho("<green>[cvar '" .. name .. "' deleted]\n")
  else
    cecho("<red>[No cvar named '" .. name .. "']\n")
  end
  return
end

-- ── GET ───────────────────────────────────────────────────────────────────
if action == "get" then
  if name == "" then
    cecho("<red>[#cvar get requires a name]\n")
    return
  end

  local entry = store[name]
  if not entry then
    cecho("<red>[No cvar named '" .. name .. "']\n")
    return
  end

  cecho("<white>cvar '" .. name .. "':\n")
  for i = 1, 4 do
    if entry[i] then
      cecho("<cyan>  [" .. i .. "] " .. entry[i] .. "\n")
    end
  end
  return
end

-- ── LIST ──────────────────────────────────────────────────────────────────
if action == "list" then
  local count = 0

  -- Collect and sort keys for consistent display order
  local keys = {}
  for k in pairs(store) do
    keys[#keys+1] = k
  end
  table.sort(keys)

  for _, k in ipairs(keys) do
    local entry = store[k]
    local parts = {}
    for i = 1, 4 do
      if entry[i] then
        parts[#parts+1] = "[" .. i .. "] " .. entry[i]
      end
    end
    cecho("<white>" .. string.format("%-20s", k) .. "  " .. table.concat(parts, "  ") .. "\n")
    count = count + 1
  end

  if count == 0 then
    cecho("<yellow>[No cvars stored]\n")
  else
    cecho("<white>[" .. count .. " cvar(s) total]\n")
  end
  return
end

-- ── FALLTHROUGH ───────────────────────────────────────────────────────────
cecho("<red>[Unknown #cvar command '" .. action .. "'. Type #cvar help]\n")
```

