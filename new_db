function loadLongDatabase()
  local filepath = getMudletHomeDir() .. "/long_stats.txt"
  local file = io.open(filepath, "r")

  if not file then
    cecho("<red>[Error: Could not open " .. filepath .. "]\n")
    return false
  end

  NyyLIB.longcache = {}
  local count = 0

  for line in file:lines() do
    if line and #line > 0 then
      local entry = parseLongStatLine(line)
      if entry then
        table.insert(NyyLIB.longcache, entry)
        count = count + 1
      end
    end
  end

  file:close()
  cecho("<green>[Loaded " .. count .. " items from long stats database]\n")
  return true
end

function parseLongStatLine(line)
  -- Format:
  -- item name (keywords) * TYPE (SLOT) * Wt:X Val:X * stats * FLAGS * Location (R) * date

  local parts = {}
  for part in line:gmatch("([^*]+)") do
    parts[#parts+1] = part:trim()
  end

  if #parts < 2 then return nil end

  -- Part 1: name (keywords)
  local fullname, keywords
  local paren = parts[1]:find("%s*%(")
  if paren then
    fullname = parts[1]:sub(1, paren - 1):trim()
    keywords = parts[1]:match("%((.-)%)%s*$") or ""
  else
    fullname = parts[1]:trim()
    keywords = ""
  end

  -- Part 2: TYPE (SLOT)
  local itype, slots = "", ""
  if parts[2] then
    local t, s = parts[2]:match("^(%S+)%s*%((.-)%)%s*$")
    if t then itype, slots = t, s
    else itype = parts[2]:trim() end
  end

  -- Remaining parts
  local wt, val = 0, 0
  local statparts, flagparts = {}, {}
  local location, rarity, date = "", "", ""

  for i = 3, #parts do
    local p = parts[i]:trim()
    if p == "" then
      -- skip
    elseif p:match("^%d%d%d%d%-%d%d%-%d%d$") then
      date = p
    elseif p:match("^Wt:%d") then
      wt  = tonumber(p:match("Wt:(%d+)")) or 0
      val = tonumber(p:match("Val:(%d+)")) or 0
    elseif p:match("%(([RNQSICX!])%)%s*$") then
      rarity   = p:match("%(([RNQSICX!])%)%s*$") or ""
      location = p:gsub("%s*%([RNQSICX!]%)%s*$",""):trim()
    elseif p:match("^[A-Z][A-Z%-%s]+$") and not p:match(":") then
      -- all-caps flags line
      for flag in p:gmatch("%S+") do
        flagparts[#flagparts+1] = flag
      end
    else
      statparts[#statparts+1] = p
    end
  end

  local stats = table.concat(statparts, " ")
  local flags = table.concat(flagparts, " ")

  return {
    fullname    = fullname,
    name_lower  = fullname:lower(),
    keywords    = keywords,
    keys_lower  = keywords:lower(),
    itype       = itype,
    slots       = slots,
    wt          = wt,
    val         = val,
    stats       = stats,
    stats_lower = stats:lower(),
    flags       = flags,
    flags_lower = flags:lower(),
    location    = location,
    rarity      = rarity,
    date        = date,
    line        = line,
    line_lower  = line:lower()
  }
end

-- Search long cache by item name
function longIdItem(xname)
  if not NyyLIB.longcache or #NyyLIB.longcache == 0 then return {} end

  local search = xname:lower()
  -- strip (poisoned)
  search = search:gsub("%(poisoned%)", ""):trim()

  local retval = {}
  for _, item in ipairs(NyyLIB.longcache) do
    if item.name_lower:find(search, 1, true) then
      retval[#retval+1] = item
    end
  end
  return retval
end

-- Advanced search with prefix operators:
--   slot:FINGER  type:WEAPON  flag:ANTI-GOOD  loc:Bahamut
--   rare:R  key:bag  date:2025  -term (NOT)
function longSearch(xsearchstr, xdisplay)
  if not NyyLIB.longcache or #NyyLIB.longcache == 0 then
    cecho("<red>[Long stats cache not loaded]\n")
    return {}
  end

  local terms = {}
  for term in xsearchstr:lower():gmatch("[^,]+") do
    terms[#terms+1] = term:trim()
  end

  local results = {}

  for _, item in ipairs(NyyLIB.longcache) do
    local match = true

    for _, term in ipairs(terms) do
      local negate = false
      if term:sub(1,1) == "-" then
        negate = true
        term = term:sub(2)
      end

      local found = false

      local prefix, val = term:match("^(%a+):(.+)$")
      if prefix and val then
        if prefix == "slot" then
          found = item.slots:lower():find(val, 1, true) ~= nil
        elseif prefix == "type" then
          found = item.itype:lower():find(val, 1, true) ~= nil
        elseif prefix == "flag" then
          found = item.flags_lower:find(val, 1, true) ~= nil
        elseif prefix == "loc" then
          found = item.location:lower():find(val, 1, true) ~= nil
        elseif prefix == "rare" then
          found = item.rarity:lower() == val
        elseif prefix == "key" then
          found = item.keys_lower:find(val, 1, true) ~= nil
        elseif prefix == "date" then
          found = item.date:find(val, 1, true) ~= nil
        else
          found = item.line_lower:find(term, 1, true) ~= nil
        end
      else
        found = item.line_lower:find(term, 1, true) ~= nil
      end

      if negate then found = not found end

      if not found then
        match = false
        break
      end
    end

    if match then
      results[#results+1] = item
    end
  end

  if xdisplay then
    longDisplayResults(results, xsearchstr)
  end

  return results
end

function longDisplayResults(results, xsearchstr)
  if #results == 0 then
    cecho("<red>[No items found matching: " .. (xsearchstr or "") .. "]\n")
    return
  end

  cecho(string.format("<cyan>--- %d result(s) for: %s ---\n", #results, xsearchstr or ""))

  for _, item in ipairs(results) do
    local raritycolor = "<white>"
    if     item.rarity == "R" then raritycolor = "<yellow>"
    elseif item.rarity == "Q" then raritycolor = "<cyan>"
    elseif item.rarity == "N" then raritycolor = "<green>"
    elseif item.rarity == "I" then raritycolor = "<magenta>"
    end

    cecho("<white>" .. item.fullname)
    if item.keywords ~= "" then
      cecho(" <dark_slate_gray>(" .. item.keywords .. ")")
    end
    if item.itype ~= "" then
      cecho(" <cornflower_blue>" .. item.itype)
    end
    if item.slots ~= "" then
      cecho(" <dark_slate_gray>(" .. item.slots .. ")")
    end
    cecho(" <dark_slate_gray>Wt:" .. item.wt .. " Val:" .. item.val)
    if item.stats ~= "" then
      cecho(" <green>" .. item.stats)
    end
    if item.flags ~= "" then
      local flagstr = item.flags
      flagstr = flagstr:gsub("(NO%-%a+)",   "<red>%1<reset>")
      flagstr = flagstr:gsub("(ANTI%-%a+)", "<orange>%1<reset>")
      cecho(" " .. flagstr)
    end
    cecho(" " .. raritycolor .. item.location)
    if item.rarity ~= "" then cecho(" (" .. item.rarity .. ")") end
    cecho("<reset>\n")
  end

  cecho("<cyan>--- End of results ---\n")
end


