function sqliditem(xitemname)
  if not NyyLIB.itemcache or #NyyLIB.itemcache == 0 then return {} end

  xitemname = xitemname:gsub("%(poisoned%)", ""):trim()
  local search = xitemname:lower()
  local retval = {}

  for _, item in ipairs(NyyLIB.itemcache) do
    if item.name_lower:find(search, 1, true) then
      retval[#retval+1] = item.stats
    end
  end
  return retval
end

function sqlshortstats(xsqlstring)
  if not NyyLIB.itemcache or #NyyLIB.itemcache == 0 then return {} end

  local sqlitems = xsqlstring:split(",")
  for i = 1, #sqlitems do sqlitems[i] = sqlitems[i]:trim() end

  local retval = {}

  for _, item in ipairs(NyyLIB.itemcache) do
    local match = true

    for _, term in ipairs(sqlitems) do
      local negate = term:sub(1,1) == "-"
      if negate then term = term:sub(2) end
      local found = item.stats_lower:find(term:lower(), 1, true) ~= nil
      if negate and found     then match = false; break end
      if not negate and not found then match = false; break end
    end

    if match then retval[#retval+1] = item.stats end
  end

  return retval
end

function sqlIsWeapon(xitemname)
  if not NyyLIB.itemcache or #NyyLIB.itemcache == 0 then return {} end
  xitemname = xitemname:gsub("'",""):lower()
  local retval = {}
  for _, item in ipairs(NyyLIB.itemcache) do
    if item.name_lower:find(xitemname, 1, true) then
      if item.stats_lower:find("%(weapon%)", 1, true) or
         item.stats_lower:find("%(ranged%)", 1, true) then
        retval[#retval+1] = item.stats
