-- search parser: space=AND, comma=OR within a term, !=NOT
local function itemMatchesSearch(line_lower, sstr)
  if sstr == "" then return true end
  for term in sstr:lower():gmatch("%S+") do
    if term:sub(1,1) == "!" then
      -- NOT: must not contain this
      local t = term:sub(2)
      if t ~= "" and line_lower:find(t, 1, true) then
        return false
      end
    elseif term:find(",") then
      -- OR group: at least one must match
      local found_any = false
      for or_term in term:gmatch("[^,]+") do
        or_term = or_term:trim()
        if or_term ~= "" and line_lower:find(or_term, 1, true) then
          found_any = true
          break
        end
      end
      if not found_any then return false end
    else
      -- AND: must contain this
      if not line_lower:find(term, 1, true) then
        return false
      end
    end
  end
  return true
end

