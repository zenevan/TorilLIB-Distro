function createconsumabledb()
  if not NyyLIB.itemcache or #NyyLIB.itemcache == 0 then
    cecho("<red>[Item cache not loaded! Cannot create consumable DB]\n")
    return
  end

  NyyLIB.itemdb = {}

  for _, item in ipairs(NyyLIB.itemcache) do
    local stats = item.stats
    local function extractConsumable(typetag)
      local pat = "%%(" .. typetag .. "%%)([A-Za-z0-9: -]+)%*"
      local retval = stats:match(pat)
      if retval then
        NyyLIB.itemdb[item.name] = { typetag:lower(), retval:trim() }
      end
    end
    extractConsumable("Potion")
    extractConsumable("Scroll")
    extractConsumable("Poison")
  end

  cecho("<red>[Consumable database cached: Potions, Scrolls, Poisons]\n")
end

-- combined lookup: tries long db first, falls back to short
function iditem(xname)
  local longresults = longIdItem(xname)
  if #longresults > 0 then return longresults[1].line end
  local shortresults = sqliditem(xname)
  if shortresults[1] then return shortresults[1] end
  return nil
end


