Trigger #2 Name: container start
regex1: When you look inside, you see:
regex2: ([A-Za-z ]+) \(carried\) :
regex3: ([A-Za-z ]+) \(worn\) : 
Lua:
enableTrigger("container contents")

noIdItems = {}

Trigger #3 Name: container contents
Regex: (.+)
Lua:
local itemname = matches[2]

if string.find(itemname, "%(carried%)") then
  return
end

-- Remove all (word) patterns: (magic), (illuminating), (glowing), (damaged), (invis)
itemname = string.gsub(itemname, " %(.+%)", "")

-- [#] itemname (i.e. multiple items)
if string.find(itemname, "] ") ~= nil then
  itemname = string.sub(itemname, string.find(itemname, "] ")+2)
end

TorilLib.bagcheck.total = TorilLib.bagcheck.total + 1

local search = TorilLib.bagcheck.search:lower()
local itemid = sqliditem(itemname)

if itemid[1] then
  local statline = itemid[1]
  local display  = string.gsub(statline, itemname, "")

  -- filter: if search set, only show items whose stat line or name matches
  if search == "" or string.find(display:lower(), search, 1, true) or string.find(itemname:lower(), search, 1, true) then
    TorilLib.bagcheck.found = TorilLib.bagcheck.found + 1
    cecho("<green>" .. display)
  end
else
  -- unknown item: check name match for search
  if search == "" or string.find(itemname:lower(), search, 1, true) then
    TorilLib.bagcheck.found = TorilLib.bagcheck.found + 1
    noIdItems[table.size(noIdItems)+1] = itemname
  end
end

--End Trigger

Trigger #4 Name: container end
Regex: ^$
Lua:
disableTrigger("container contents")
disableTrigger("container end")

local search = TorilLib.bagcheck.search
local found  = TorilLib.bagcheck.found
local total  = TorilLib.bagcheck.total

if search ~= "" then
  cecho("<white>[" .. found .. " match(es) for '" .. search .. "' out of " .. total .. " item(s)]\n")
else
  cecho("<white>[" .. total .. " item(s) in bag]\n")
end

if #noIdItems > 0 then
  cecho("<yellow>[Unidentified items:]\n")
  for _, v in ipairs(noIdItems) do
    cecho("<yellow>  " .. v .. "\n")
  end
end

enableTrigger("DisplayPotions")

--End Trigger
